# Rust
/target/
**/*.rs.bk
Cargo.lock

# Tauri
src-tauri/target/

# Frontend
# NOTE: no trailing slash — matches BOTH the real dir AND a symlink of this
# name (a worktree's frontend/node_modules is a symlink to the canonical install).
frontend/node_modules
frontend/dist/
frontend/.next/
*.tsbuildinfo

# IDE
.idea/
.vscode/
*.swp
*.swo
*.iml

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment
.env
.env.*
!.env.example

# Contracts generated
contracts/generated/

# Database
*.db
*.db-wal
*.db-shm

# Build artifacts
*.wasm
*.exe

# Logs
*.log

# Masday runtime artifacts (ignore everything under .masday/ EXCEPT the
# intentionally-tracked curated dirs + the shared node_modules helper).
.masday/*
!.masday/intel/
!.masday/research/
!.masday/link-node-modules.sh
