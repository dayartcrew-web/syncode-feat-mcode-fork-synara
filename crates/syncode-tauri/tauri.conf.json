{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/tooling/cli/schema.json",
  "productName": "Syncode",
  "version": "0.1.9",
  "identifier": "dev.syncode.app",
  "build": {
    "frontendDist": "../../frontend/dist",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Syncode",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob: http://127.0.0.1:* http://localhost:* http://tauri.localhost; connect-src 'self' ipc: http://ipc.localhost http://tauri.localhost ws://127.0.0.1:* ws://localhost:* http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src-attr 'unsafe-inline'; font-src 'self' data: https://fonts.gstatic.com; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage", "dmg", "app"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico", "icons/icon.png"],
    "publisher": "Syncode",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1Qzk4Rjk0MDEyRUIwQzYKUldUR3NDNEJsSS9KZFZVcHY5TUljMTVxMnJjQnhRWEcxdWs5VFVhSktKdUpwTm9sdzdvZ285bjIK",
      "endpoints": ["https://github.com/dayartcrew-web/syncode-feat-mcode-fork-synara/releases/latest/download/latest.json"]
    }
  }
}
