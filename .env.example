# .env.example — copy to .env and adjust before `docker compose up`.
#
# Every variable here is read by docker-compose.yml and substituted into the
# service's `environment:` block. Values use the documented default when left
# unset (Compose sees the empty string and the container falls back to its own
# default). Lines you do not change can stay or be deleted — only the variables
# you want to override need to be present in .env.
#
#   cp .env.example .env
#   # edit .env, then:
#   docker compose up --build

# ─── Network listener ───────────────────────────────────────────────────────
# Bind host for the WS + HTTP listener. Set to 0.0.0.0 inside the container so
# the published port (3000) reaches the server. Override only if you run the
# binary directly (host mode) and want loopback-only.
SYNCODE_WS_HOST=0.0.0.0

# Bind port. Must match the `ports:` mapping in docker-compose.yml (default
# 3000:3000). Change both together if you want a different host port.
SYNCODE_WS_PORT=3000

# ─── Storage ────────────────────────────────────────────────────────────────
# SQLite DB path. The default (/app/data/syncode.db) lands inside the bind
# mount (./data:/app/data) so the DB survives container restarts. Set to an
# empty string (SYNCODE_DB=) to force in-memory storage (lost on restart —
# useful for ephemeral testing).
SYNCODE_DB=/app/data/syncode.db

# ─── Chat pipeline ──────────────────────────────────────────────────────────
# Provider id armed for the chat pipeline. The server looks up the matching
# adapter in the provider registry; if it is not installed the server boots but
# turns are recorded with no AI response. Known ids: claude, gemini, cursor,
# kilo, opencode, pi, codex, opencode, amp, qwq (depending on installation).
SYNCODE_DEFAULT_PROVIDER=claude

# ─── Logging ────────────────────────────────────────────────────────────────
# tracing filter (tracing-subscriber EnvFilter syntax). Increase to debug for
# verbose per-request logs, e.g. SYNCODE_LOG=syncode_ws=debug,info.
RUST_LOG=syncode_ws=info,info

# ─── Optional: skills / plugins dirs ────────────────────────────────────────
# Override where the server looks for skills and plugin manifests. Inside the
# container these default to a config dir under the server's working directory;
# mount a host directory and point these at it to ship custom skills/plugins
# with the image. Leave unset to use the built-in defaults.
# SYNCODE_SKILLS_DIR=/app/skills
# SYNCODE_PLUGINS_DIR=/app/plugins
