# .dockerignore — excludes from the Docker build context.
#
# Goal: keep the build context small (faster `docker build` context upload) and
# prevent host-side artifacts (Rust target/, Node node_modules/, local DB files,
# editor/OS noise) from leaking into the image. Build outputs are produced
# inside the builder stage — they do not need to be present on the host.

# --- Version control / metadata ---------------------------------------------
.git
.gitignore
.gitattributes
.github

# --- Rust -------------------------------------------------------------------
# target/ holds host-built artifacts (potentially many GB). The builder stage
# produces its own target/ inside the image and is the source of truth.
target/
**/*.rs.bk
# Cargo.lock is gitignored by the project and regenerated by cargo inside the
# builder — sending a stale host copy would force `--locked` mismatches.
Cargo.lock

# --- Frontend build artifacts -----------------------------------------------
# node_modules is huge (often 1+ GB) and `npm ci` reinstalls it inside the
# builder from package-lock.json. dist/ is a build output too.
frontend/node_modules/
frontend/node_modules
frontend/dist/
frontend/.next/
*.tsbuildinfo

# --- Tauri desktop build (not needed for WS server image) -------------------
src-tauri/
**/src-tauri/target/

# --- Masday / workflow runtime artifacts ------------------------------------
# .masday/ is the orchestrator's state (worktrees, reports, intel). It is never
# needed inside the image and frequently contains symlinks that break docker
# context upload. The .playwright-mcp/ dir is browser-test scratch space.
.masday/
.playwright-mcp/

# --- Local databases / logs / caches ----------------------------------------
*.db
*.db-wal
*.db-shm
*.log
*.wasm

# --- Editor / OS noise ------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.iml
.DS_Store
Thumbs.db
desktop.ini

# --- Environment / secrets --------------------------------------------------
# Never bake local .env files into the image — pass secrets via runtime env /
# secrets / volume mounts instead.
.env
.env.*
!.env.example

# --- Generated contracts ----------------------------------------------------
contracts/generated/

# --- Docker meta (avoids recursive context churn) ---------------------------
Dockerfile
.dockerignore

# --- Test scratch / reports -------------------------------------------------
TEST_SUMMARY.md
