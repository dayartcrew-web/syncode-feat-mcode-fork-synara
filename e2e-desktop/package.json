{
  "name": "syncode-e2e-desktop",
  "private": true,
  "version": "0.0.0",
  "description": "WebdriverIO desktop functional tests for the Syncode Tauri app (embedded WebDriver).",
  "type": "module",
  "scripts": {
    "build:test-binary": "(cd ../ && cargo build --release -p syncode-tauri --features webdriver)",
    "test": "wdio run wdio.conf.ts",
    "test:smoke": "wdio run wdio.conf.ts --suite smoke"
  },
  "dependencies": {
    "@wdio/cli": "^9.0.0",
    "@wdio/tauri-service": "^1.2.0",
    "@wdio/native-utils": "^2.5.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "webdriverio": "^9.0.0",
    "expect-webdriverio": "^5.0.0"
  },
  "overrides": {
    "@wdio/native-utils": "^2.5.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0",
    "@types/mocha": "^10.0.0"
  }
}
