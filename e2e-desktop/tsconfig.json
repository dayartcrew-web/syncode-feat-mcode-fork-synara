{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "mocha", "@wdio/globals/types", "webdriverio/async", "expect-webdriverio"],
    "lib": ["ES2022", "DOM"]
  },
  "include": ["*.ts", "test/**/*.ts"]
}
